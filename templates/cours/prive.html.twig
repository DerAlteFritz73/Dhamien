<section id="beatbox">
    <h2>Beatbox</h2>
    <div class="looper-controls">
        <h5>Beatbox Looper</h5>
        <div class="text-center" style="margin-bottom: 12px;">
            <button onclick="play()" class="btn-play">PLAY</button>
            <button onclick="stop()" class="btn-stop">STOP</button>
        </div>
        <div class="text-center" style="margin-bottom: 8px;">
            <span>Mélodie : </span>
            <span class="radio-group">
                <input type="radio" id="melodieon" name="melodie" onclick="muteMelodie(false)">
                <label for="melodieon">ON</label>
                <input type="radio" id="melodieoff" name="melodie" onclick="muteMelodie(true)" checked>
                <label for="melodieoff">OFF</label>
            </span>
        </div>
        <div class="text-center">
            <span>Rythme : </span>
            <span class="radio-group">
                <input type="radio" id="clave" name="rythme" onclick="toggleClave()">
                <label for="clave">CLAVE</label>
                <input type="radio" id="hiphop" name="rythme" onclick="toggleHiphop()">
                <label for="hiphop">HIPHOP</label>
                <input type="radio" id="rock" name="rythme" onclick="toggleRock()">
                <label for="rock">ROCK</label>
                <input type="radio" id="off" name="rythme" onclick="toggleOff()" checked>
                <label for="off">OFF</label>
            </span>
        </div>
    </div>
    <ul>
        <li><a href="/media/cours/beatbox_groove_variations.pdf">Grooves et variations</a></li>
        <li><a href="/media/cours/beatbox_legende.pdf">Légende</a></li>
    </ul>
</section>

