{% block javascripts %}
    {{ parent() }}
    <script src="https://unpkg.com/tone"></script>
    <script>
        const melodie = new Tone.Player('/media/looper/dhamien_bb_melodie.mp3').toDestination();
        melodie.loop = true;
        melodie.mute = true;
        const clave_s = new Tone.Player('/media/looper/dhamien_bb_clave.mp3').toDestination();
        clave_s.loop = true;
        clave_s.mute = true;
        const hiphop_s = new Tone.Player('/media/looper/dhamien_bb_hiphop.mp3').toDestination();
        hiphop_s.loop = true;
        hiphop_s.mute = true;
        const rock_s = new Tone.Player('/media/looper/dhamien_bb_rock.mp3').toDestination();
        rock_s.loop = true;
        rock_s.mute = true;

        function play() {
            Tone.start();
            melodie.start();
            clave_s.start();
            hiphop_s.start();
            rock_s.start();
        }

        function stop() {
            melodie.stop();
            clave_s.stop();
            hiphop_s.stop();
            rock_s.stop();
        }

        function muteMelodie(mute) {
            melodie.mute = mute;
        }

        function toggleClave() {
            clave_s.mute = false;
            hiphop_s.mute = true;
            rock_s.mute = true;
        }

        function toggleHiphop() {
            hiphop_s.mute = false;
            rock_s.mute = true;
            clave_s.mute = true;
        }

        function toggleRock() {
            rock_s.mute = false;
            clave_s.mute = true;
            hiphop_s.mute = true;
        }

        function toggleOff() {
            rock_s.mute = true;
            clave_s.mute = true;
            hiphop_s.mute = true;
        }
    </script>
