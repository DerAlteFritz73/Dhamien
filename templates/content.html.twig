{# Content page layout - extends base and adds the overlay panel #}
{% extends 'base.html.twig' %}

{% block main %}
<div class="fixed top-0 left-0 w-screen h-screen bg-black opacity-80"> </div>
<div class="fixed top-0 left-0 w-screen h-screen flex justify-center content-overlay" style="padding: 20px;">
  <div class="content-panel rounded drop-shadow-md my-2" style="background-image: url('/media/img/body.jpg'); max-height: calc(100vh - 40px); overflow-y: auto; overflow-x: hidden;">
      <div class="float-right text-lg text-white p-2">
        <a onclick="history.back(); return false;" href="{{ path('app_home') }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6">
            <path fill-rule="evenodd"
              d="M12 2.25c-5.385 0-9.75 4.365-9.75 9.75s4.365 9.75 9.75 9.75 9.75-4.365 9.75-9.75S17.385 2.25 12 2.25Zm-1.72 6.97a.75.75 0 1 0-1.06 1.06L10.94 12l-1.72 1.72a.75.75 0 1 0 1.06 1.06L12 13.06l1.72 1.72a.75.75 0 1 0 1.06-1.06L13.06 12l1.72-1.72a.75.75 0 1 0-1.06-1.06L12 10.94l-1.72-1.72Z"
              clip-rule="evenodd" />
          </svg>
        </a>
      </div>
      <div class="rounded-t text-white p-2" style="background-image: url('/media/img/barre.jpg')">
        <h1 class="text-lg font-bold">{% block heading %}{% endblock %}</h1>
      </div>
      <div class="prose lg:prose-xl p-2 lg:p-4 content-prose">
        {% block body %}{% endblock %}
      </div>
    </div>
  </div>
</div>
{% endblock %}
