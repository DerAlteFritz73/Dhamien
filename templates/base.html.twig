<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="utf-8">
    <meta name="description" content="Dhamien Schmutz - Percussionniste, musicien, pédagogue / Percussionist, musician, educator">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}dhamien.fr{% endblock %}</title>
    <link href="/css/styles.css" rel="stylesheet">
    <link href="/css/carousel.css" rel="stylesheet">
    <script src="/js/carousel.js"></script>
    <script src="/js/responsive-imagemap.js"></script>
    <script src="/js/center-accordion.js"></script>
    {% block stylesheets %}{% endblock %}
    {% block head %}{% endblock %}
    {# Apply saved language before first paint to prevent flash #}
    <script>(function(){var l=localStorage.getItem('dhamien-lang')||'fr';document.documentElement.classList.add('lang-'+l);document.documentElement.lang=l;})();</script>
  </head>
  <body class="relative">
    {# Determine current section from URL #}
    {% set section = app.request.pathInfo|split('/')[1]|default('') %}

    {# Mobile navigation #}
    <nav class="mobile-nav">
      <button class="mobile-nav-toggle" onclick="document.querySelector('.mobile-nav-menu').classList.toggle('open')">
        <span></span><span></span><span></span>
      </button>
      <div class="mobile-nav-menu">
        <a href="{{ path('app_home') }}"><span class="i18n-fr">Accueil</span><span class="i18n-en">Home</span></a>
        <a href="{{ path('page_musique') }}"><span class="i18n-fr">Musique</span><span class="i18n-en">Music</span></a>
        <a href="{{ path('page_spectacles') }}"><span class="i18n-fr">Spectacles</span><span class="i18n-en">Shows</span></a>
        <a href="{{ path('page_biographie') }}"><span class="i18n-fr">Biographie</span><span class="i18n-en">Biography</span></a>
        <a href="{{ path('page_stage') }}"><span class="i18n-fr">Stages</span><span class="i18n-en">Workshops</span></a>
        <a href="{{ path('page_prive') }}"><span class="i18n-fr">Ressources</span><span class="i18n-en">Resources</span></a>
        <a href="{{ path('page_voyages_photos') }}"><span class="i18n-fr">Photos de voyage</span><span class="i18n-en">Travel Photos</span></a>
        <a href="{{ path('page_contact') }}">Contact</a>
        <a href="{{ path('page_presentation') }}"><span class="i18n-fr">Présentation</span><span class="i18n-en">About</span></a>
        <a href="{{ path('page_infos_photos') }}">Photos</a>
        <a href="{{ path('page_presse') }}"><span class="i18n-fr">Presse</span><span class="i18n-en">Press</span></a>
        <a href="{{ path('page_liens') }}"><span class="i18n-fr">Liens</span><span class="i18n-en">Links</span></a>
        <a href="{{ path('page_merci') }}"><span class="i18n-fr">Merci</span><span class="i18n-en">Credits</span></a>
        <a href="{{ path('page_agenda') }}"><span class="i18n-fr">Agenda</span><span class="i18n-en">Calendar</span></a>
      </div>
    </nav>

    {# Language switcher signs #}
    <div id="lang-switcher">
      <button class="lang-sign" id="sign-fr" onclick="setLang('fr')">
        <span class="sign-dot"></span>
        Vous êtes ici
      </button>
      <button class="lang-sign" id="sign-en" onclick="setLang('en')">
        <span class="sign-dot"></span>
        You are here
      </button>
    </div>

    <div class="mx-auto" style="max-width: 1600px; width: 100%; padding: 0 20px;">
      <div class="flex flex-col items-center justify-center min-h-screen">
        <section id="accueil">
          <a href="{{ path('app_home') }}">
            <img class="max-w-full i18n-fr" src="/media/img/accueil.jpg" alt="accueil">
            <img class="max-w-full i18n-en" src="/media/img/accueil_en.jpg" alt="accueil">
          </a>
        </section>
        <section id="musique">
          {% if section == 'musique' %}
          <a href="{{ path('app_home') }}">
            <img class="max-w-full" src="/media/img/musique.jpg" alt="musique">
          </a>
          <div class="submenu-wrapper">
            <img class="max-w-full" src="/media/img/menu_musique.jpg" usemap="#musiqueMap" alt="musique-menu">
            <map name="musiqueMap">
              <area shape="poly" coords="10,144,0,230,40,230,47,178,189,37,170,23,120,71,102,57,10,143" href="{{ path('page_musique') }}">
              <area shape="poly" coords="424,156,415,230,460,230,445,175,508,109,491,95,423,156" href="{{ path('page_spectacles') }}">
            </map>
          </div>
          {% else %}
          <a href="{{ path('section_musique') }}">
            <img class="max-w-full" src="/media/img/musique.jpg" alt="musique">
          </a>
          {% endif %}
        </section>
        <section id="cours">
          {% if section == 'cours' %}
          <a href="{{ path('app_home') }}">
            <img class="max-w-full" src="/media/img/cours.jpg" alt="cours">
          </a>
          <div class="submenu-wrapper">
            <img class="max-w-full" src="/media/img/menu_cours.jpg" usemap="#coursMap" alt="cours-menu">
            <map name="coursMap">
              <area shape="poly" coords="22,153,121,52,151,76,49,176,40,230,0,230,21,152" href="{{ path('page_biographie') }}">
              <area shape="poly" coords="249,145,355,43,376,56,426,7,447,25,285,182,285,230,248,230,248,144" href="{{ path('page_stage') }}">
              <area shape="poly" coords="422,152,533,40,557,74,449,178,460,230,415,230,422,152" href="{{ path('page_prive') }}">
            </map>
          </div>
          {% else %}
          <a href="{{ path('section_cours') }}">
            <img class="max-w-full" src="/media/img/cours.jpg" alt="cours">
          </a>
          {% endif %}
        </section>
        <section id="voyages">
          {% if section == 'voyages' %}
          <a href="{{ path('app_home') }}">
            <img class="max-w-full" src="/media/img/voyages.jpg" alt="voyages">
          </a>
          <div class="submenu-wrapper">
            <img class="max-w-full" src="/media/img/menu_voyages.jpg" alt="voyages-menu" usemap="#voyagesMap">
            <map name="voyagesMap">
              <area shape="poly" coords="173,151,233,95,257,119,203,174,210,230,163,230,172,150" href="{{ path('page_voyages_photos') }}">
              <area shape="poly" coords="504,155,554,104,585,134,536,184,548,230,498,230,505,155" href="{{ path('page_voyages_blog') }}">
            </map>
          </div>
          {% else %}
          <a href="{{ path('section_voyages') }}">
            <img class="max-w-full" src="/media/img/voyages.jpg" alt="voyages">
          </a>
          {% endif %}
        </section>
        <section id="infos">
          {% if section == 'infos' %}
          <a href="{{ path('app_home') }}">
            <img class="max-w-full" src="/media/img/infos.jpg" alt="infos">
          </a>
          <div class="submenu-wrapper">
            <img class="max-w-full" src="/media/img/menu_infos.jpg" alt="infos" usemap="#infosMap">
            <map name="infosMap">
              <area shape="poly" coords="21,149,103,65,129,88,44,175,40,230,0,230,21,149" href="{{ path('page_contact') }}">
              <area shape="poly" coords="86,149,175,59,191,74,248,20,271,42,127,186,130,230,78,230,87,148" href="{{ path('page_presentation') }}">
              <area shape="poly" coords="337,151,417,78,444,102,369,181,375,230,325,230,337,151" href="{{ path('page_infos_photos') }}">
              <area shape="poly" coords="422,153,501,78,526,102,447,175,455,230,410,230,420,152" href="{{ path('page_presse') }}">
            </map>
          </div>
          {% else %}
          <a href="{{ path('section_infos') }}">
            <img class="max-w-full" src="/media/img/infos.jpg" alt="infos">
          </a>
          {% endif %}
        </section>
        <section id="liens">
          {% if section == 'liens' %}
          <a href="{{ path('app_home') }}">
            <img class="max-w-full" src="/media/img/liens.jpg" alt="liens">
          </a>
          <div class="submenu-wrapper">
            <img class="max-w-full" src="/media/img/menu_liens.jpg" usemap="#liensMap" alt="liens">
            <map name="liensMap">
              <area shape="poly" coords="15,152,77,97,100,116,39,175,40,230,0,230,14,152" href="{{ path('page_liens') }}">
              <area shape="poly" coords="483,89,423,150,410,230,460,230,449,177,511,114,484,88" href="{{ path('page_merci') }}">
            </map>
          </div>
          {% else %}
          <a href="{{ path('section_liens') }}">
            <img class="max-w-full" src="/media/img/liens.jpg" alt="liens">
          </a>
          {% endif %}
        </section>
        <section id="agenda">
          <a href="{{ path('page_agenda') }}">
            <img class="max-w-full" src="/media/img/agenda.jpg" alt="agenda">
          </a>
        </section>
        {% block main %}{% endblock %}
      </div>
    </div>

    {% block javascripts %}{% endblock %}

    <script>
    function setLang(l) {
      var html = document.documentElement;
      html.classList.remove('lang-fr', 'lang-en');
      html.classList.add('lang-' + l);
      html.lang = l;
      var signFr = document.getElementById('sign-fr');
      var signEn = document.getElementById('sign-en');
      if (signFr) signFr.classList.toggle('active', l === 'fr');
      if (signEn) signEn.classList.toggle('active', l === 'en');
      localStorage.setItem('dhamien-lang', l);
      var cal = document.getElementById('calendar-iframe');
      if (cal) cal.src = cal.getAttribute('data-src-' + l);
    }
    (function() {
      var l = localStorage.getItem('dhamien-lang') || 'fr';
      var signFr = document.getElementById('sign-fr');
      var signEn = document.getElementById('sign-en');
      if (signFr) signFr.classList.toggle('active', l === 'fr');
      if (signEn) signEn.classList.toggle('active', l === 'en');
    })();
    </script>
  </body>
</html>
